# Generate JWT secrets with: openssl rand -base64 48

NODE_ENV=development

# Postgres — postgres 공식 이미지가 인식하는 표준 변수 이름
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
# compose 네트워크에서는 'postgres', 호스트 직접 실행 시 'localhost'
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT 시크릿 — 최소 32자, 두 값이 반드시 달라야 한다
JWT_ACCESS_SECRET=replace_with_openssl_rand_base64_48_output_1
JWT_REFRESH_SECRET=replace_with_openssl_rand_base64_48_output_2

# JWT 만료 시간 (duration 문자열: s/m/h/d)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=1d

# bcrypt 해싱 라운드 (10–14, 12 권장 — 약 300ms)
BCRYPT_ROUNDS=12

# 쿠키 보안 플래그 — prod에서는 반드시 true
COOKIE_SECURE=false
# 쿠키 도메인 — 기본 비워둠(Host-only)
COOKIE_DOMAIN=

# CORS 허용 출처 — prod에서는 https URI만 허용
FRONTEND_ORIGIN=http://localhost:3000

# 한국관광공사 국문 관광정보 API — 공공데이터포털 발급 키 중 Decoding(원본) 키 사용
TOUR_API_KEY=replace_with_decoded_service_key
