{
  "name": "limjaejoon-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "tools/harness"
  ],
  "scripts": {
    "dev:fe": "npm run dev -w frontend",
    "dev:be": "npm run dev -w backend",
    "build:fe": "npm run build -w frontend",
    "build:be": "npm run build -w backend",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:fe": "npm run test -w frontend",
    "test:be": "npm run test -w backend",
    "harness": "tsx tools/harness/src/execute.ts"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "tsx": "^4.19.2"
  }
}
